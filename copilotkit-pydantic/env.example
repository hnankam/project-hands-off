# =============================================================================
# Pydantic AI Agent Server - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8001

# Debug mode (default: false)
# WARNING: Never enable DEBUG in production! It exposes sensitive information.
DEBUG=false

# Environment (production, staging, development)
PYTHON_ENV=development

# Log format: plain or json (json recommended for production)
LOG_FORMAT=plain

# CORS allowed origins (comma-separated, use * for all in development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,chrome-extension://*

# Maximum request body size in MB (default: 30)
MAX_REQUEST_SIZE_MB=30

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# REQUIRED: Master secret for credential encryption
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# CRITICAL: Must be set to a secure value in production!
ENCRYPTION_MASTER_SECRET=

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL/Neon)
# -----------------------------------------------------------------------------

# Database connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/copilotkit

# Connection pool settings (optimized for Neon serverless)
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis Configuration (Distributed Caching & State)
# -----------------------------------------------------------------------------

# Enable Redis (default: true)
# WARNING: Disabling Redis makes multi-instance deployment impossible!
REDIS_ENABLED=true

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis SSL (for managed Redis services)
REDIS_SSL=false

# Redis connection pool
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------

# Default rate limit for all endpoints (format: "requests/period")
# Periods: second, minute, hour, day
RATE_LIMIT_DEFAULT=100/minute

# Agent endpoint rate limit (typically lower for resource-intensive operations)
RATE_LIMIT_AGENT=60/minute

# Admin endpoint rate limit
RATE_LIMIT_ADMIN=120/minute

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# Ably Pub/Sub (for real-time usage streaming)
ABLY_API_KEY=

# Google AI API (for Gemini models)
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Observability - Logfire
# -----------------------------------------------------------------------------

# Enable Logfire observability (default: true if token provided)
LOGFIRE_ENABLED=false
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=copilotkit-pydantic
LOGFIRE_ENVIRONMENT=development
LOGFIRE_CAPTURE_HEADERS=true

# =============================================================================
# Production Deployment Checklist
# =============================================================================
#
# Before deploying to production, ensure:
#
# 1. ✅ DEBUG=false
# 2. ✅ ENCRYPTION_MASTER_SECRET is set to a strong, unique value
# 3. ✅ PYTHON_ENV=production
# 4. ✅ DATABASE_URL points to production database
# 5. ✅ REDIS_ENABLED=true with production Redis instance
# 6. ✅ Rate limits are configured appropriately
# 7. ✅ ALLOWED_ORIGINS is set to specific domains (not *)
# 8. ✅ LOG_FORMAT=json for structured logging
# 9. ✅ All API keys (ABLY_API_KEY, GOOGLE_API_KEY) are set
# 10. ✅ LOGFIRE_ENABLED=true for production monitoring
#
# =============================================================================
