# =============================================================================
# MCP Servers - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Required: All MCP servers need database access for credential resolution

DB_HOST=your-postgres-host
DB_PORT=5432
DB_DATABASE=your-database-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_OTHER_PARAMS=sslmode=require

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Required: Master secret for credential encryption/decryption

ENCRYPTION_MASTER_SECRET=your-encryption-secret-change-in-production

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
# Optional: Logfire integration for monitoring

LOGFIRE_TOKEN=
LOGFIRE_ENABLED=false
LOGFIRE_SERVICE_NAME=mcp-servers
LOGFIRE_ENVIRONMENT=development

# =============================================================================
# Port Allocation (Do not modify unless necessary)
# =============================================================================
#
# Each MCP server runs on a dedicated port:
#   - GitHub:       8101
#   - Jira:         8102
#   - Confluence:   8103
#   - Databricks:   8104
#   - Microsoft365: 8105
#
# These ports are configured in docker-compose.yml and individual Dockerfiles.
# Only modify if you have port conflicts.
#
# =============================================================================

# =============================================================================
# Production Deployment Checklist
# =============================================================================
#
# Before deploying to production, ensure:
#
# 1. ✅ DB_HOST points to production PostgreSQL instance
# 2. ✅ DB_PASSWORD is strong and secure
# 3. ✅ ENCRYPTION_MASTER_SECRET is set to a strong, unique value
# 4. ✅ Database has workspace_credentials table properly configured
# 5. ✅ All required credentials are stored in database
# 6. ✅ Network security groups allow access to MCP server ports
# 7. ✅ SSL certificates configured (if using HTTPS)
# 8. ✅ LOGFIRE_ENABLED=true for production monitoring (optional)
#
# =============================================================================
