# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your production values
# cp env.docker.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------

# Master secret for credential encryption (REQUIRED)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ENCRYPTION_MASTER_SECRET=

# JWT secret for Node.js service (REQUIRED)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

PYTHON_ENV=production
NODE_ENV=production
DEBUG=false
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Database Configuration (Managed SaaS - Neon, AWS RDS, etc.)
# -----------------------------------------------------------------------------

# REQUIRED: PostgreSQL connection details
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_OTHER_PARAMS=sslmode=require

# Connection pool settings
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# -----------------------------------------------------------------------------
# Redis Configuration (Managed SaaS - Redis Cloud, AWS ElastiCache, etc.)
# -----------------------------------------------------------------------------

# REQUIRED: Redis connection details
REDIS_ENABLED=true
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=true

# Redis database numbers (separate DBs for each service)
REDIS_DB=0           # Python service
REDIS_DB_RUNTIME=1   # Node.js service

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# Ably Pub/Sub (for real-time usage streaming)
ABLY_API_KEY=

# Google AI API (for Gemini models)
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Observability - Logfire
# -----------------------------------------------------------------------------

LOGFIRE_ENABLED=true
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=copilotkit-pydantic
LOGFIRE_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Service Ports (Optional)
# -----------------------------------------------------------------------------

PYDANTIC_PORT=8001
RUNTIME_PORT=3001

# Python Backend URL (automatically set in Docker Compose)
# For local development outside Docker: http://localhost:8001
# PYDANTIC_SERVICE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Production Deployment Checklist
# -----------------------------------------------------------------------------
#
# Before deploying to production:
#
# 1. ✅ ENCRYPTION_MASTER_SECRET is set to a strong, unique value
# 2. ✅ JWT_SECRET is set to a strong, unique value
# 3. ✅ All database connection details are configured
# 4. ✅ All Redis connection details are configured
# 5. ✅ REDIS_SSL=true for managed Redis services
# 6. ✅ DB_OTHER_PARAMS includes sslmode=require
# 7. ✅ DEBUG=false
# 8. ✅ PYTHON_ENV=production and NODE_ENV=production
# 9. ✅ LOG_FORMAT=json for structured logging
# 10. ✅ External service API keys are configured
#
# =============================================================================
