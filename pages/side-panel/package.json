{
  "name": "@extension/sidepanel",
  "version": "0.5.1",
  "description": "chrome extension - side panel",
  "type": "module",
  "private": true,
  "sideEffects": true,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "clean:node_modules": "pnpx rimraf node_modules",
    "clean:turbo": "rimraf .turbo",
    "clean": "pnpm clean:turbo && pnpm clean:node_modules",
    "build": "vite build",
    "dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.42",
    "@better-auth/sso": "^1.4.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@copilotkit/react-core": "1.50.1-next.1",
    "@copilotkit/react-ui": "1.50.1-next.1",
    "@copilotkit/shared": "1.50.1-next.1",
    "@copilotkitnext/core": "^0.0.27",
    "@copilotkitnext/react": "^0.0.27",
    "@extension/i18n": "workspace:*",
    "@extension/shared": "workspace:*",
    "@extension/storage": "workspace:*",
    "@extension/ui": "workspace:*",
    "@tiptap/html": "^3.10.7",
    "ably": "^2.4.0",
    "better-auth": "1.4.5",
    "codemirror": "^6.0.2",
    "d3-sankey": "^0.12.3",
    "dompurify": "^3.2.2",
    "firebase": "^11.1.0",
    "html2canvas": "1.4.1",
    "mermaid": "^10.9.1",
    "rehype-raw": "^7.0.0",
    "streamdown": "^1.6.10",
    "tiptap-markdown": "^0.9.0",
    "virtua": "^0.47.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@extension/tailwindcss-config": "workspace:*",
    "@extension/tsconfig": "workspace:*",
    "@extension/vite-config": "workspace:*",
    "@types/dompurify": "^3.2.0"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
