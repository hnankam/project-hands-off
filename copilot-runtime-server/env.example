# =============================================================================
# CopilotKit Runtime Server - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Debug mode (default: false in production)
DEBUG=false

# Python agent service URL (pydantic backend)
# In Docker Compose: http://copilotkit-pydantic:8001
# Local development: http://localhost:8001
PYDANTIC_SERVICE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------

# Master secret for credential encryption (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_SECRET=

# Better Auth secret for session encryption (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=

# Better Auth base URL (for OAuth callbacks)
BETTER_AUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------

# PostgreSQL connection details
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=copilotkit
DB_USERNAME=copilotkit
DB_PASSWORD=changeme
DB_OTHER_PARAMS=sslmode=require

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# OAuth Configuration (Optional)
# -----------------------------------------------------------------------------

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Firebase Storage (Optional)
# -----------------------------------------------------------------------------

FIREBASE_STORAGE_BUCKET=
FIREBASE_API_KEY=

# -----------------------------------------------------------------------------
# Agent Runner Configuration
# -----------------------------------------------------------------------------

# Use SQLite instead of PostgreSQL (default: false)
USE_SQLITE_RUNNER=false
SQLITE_DB_PATH=./copilotkit.db

# Max historic runs to load per thread
AGENT_RUNNER_MAX_HISTORIC_RUNS=1000

# Transform error runs to finished runs (shows in history)
AGENT_RUNNER_TRANSFORM_ERRORS=false

# Disable automatic thread cleanup (default: true = cleanup disabled)
# Set to false to enable automatic deletion of inactive threads
AGENT_RUNNER_DISABLE_CLEANUP=true

# Thread TTL in milliseconds (default: 86400000 = 24 hours)
# Only used if AGENT_RUNNER_DISABLE_CLEANUP=false
# Threads inactive for longer than this will be deleted
AGENT_RUNNER_THREAD_TTL=86400000

# Cleanup interval in milliseconds (default: 3600000 = 1 hour)
# Only used if AGENT_RUNNER_DISABLE_CLEANUP=false
# How often to run the cleanup process
AGENT_RUNNER_CLEANUP_INTERVAL=3600000

# -----------------------------------------------------------------------------
# Server Limits
# -----------------------------------------------------------------------------

# Maximum request body size (MB)
BODY_LIMIT_MB=30

# Request timeout (ms) - 5 minutes for long-running agents
REQUEST_TIMEOUT_MS=300000

# Headers timeout (ms) - slightly longer than request timeout
HEADERS_TIMEOUT_MS=310000

# Trust proxy headers (enable if behind load balancer)
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Allowed CORS origins (comma-separated)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Production Deployment Checklist
# -----------------------------------------------------------------------------
#
# Before deploying to production:
#
# 1. ✅ NODE_ENV=production
# 2. ✅ ENCRYPTION_MASTER_SECRET is set to a strong, unique value
# 3. ✅ BETTER_AUTH_SECRET is set to a strong, unique value
# 4. ✅ BETTER_AUTH_URL points to production URL
# 5. ✅ All database connection details are configured
# 6. ✅ DB_OTHER_PARAMS includes sslmode=require
# 7. ✅ DEBUG=false
# 8. ✅ CORS_ORIGINS is set to specific domains (not empty)
# 9. ✅ OAuth credentials configured (if using OAuth)
# 10. ✅ TRUST_PROXY=true if behind load balancer
#
# =============================================================================
