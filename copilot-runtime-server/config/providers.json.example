{
  "providers": {
    "google": {
      "type": "google",
      "name": "Google Generative AI",
      "enabled": true,
      "credentials": {
        "api_key": "your-google-api-key-here"
      },
      "default_settings": {
        "prompt_caching": {
          "enabled": true,
          "debug": false
        }
      }
    },
    "anthropic_bedrock": {
      "type": "anthropic_bedrock",
      "name": "Anthropic Bedrock",
      "enabled": true,
      "credentials": {
        "aws_access_key_id": "your-aws-access-key-id",
        "aws_secret_access_key": "your-aws-secret-access-key",
        "aws_region": "us-east-1"
      },
      "default_settings": {
        "prompt_caching": {
          "enabled": true,
          "debug": false
        }
      }
    },
    "azure_openai": {
      "type": "azure_openai",
      "name": "Azure OpenAI",
      "enabled": true,
      "credentials": {
        "api_key": "your-azure-openai-api-key",
        "endpoint": "https://your-instance.openai.azure.com",
        "base_url": "https://your-instance.openai.azure.com"
      },
      "azure_config": {
        "instance": "your-instance-name",
        "api_version": "2024-04-01-preview",
        "api_version_alt": "2025-01-01-preview"
      },
      "default_settings": {
        "prompt_caching": {
          "enabled": false,
          "debug": false
        }
      }
    }
  }
}

