# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# This file contains environment variables for the Chrome Extension frontend.
# Copy this file to .env and update the values for your environment.
#
# Build-time variables (prefix with VITE_) are embedded in the frontend bundle
# and accessible via import.meta.env in the code.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Service URLs
# -----------------------------------------------------------------------------

# Runtime Server (Node.js) - Main API endpoint
# Used for: Authentication, Configuration, CopilotKit chat, Admin APIs, Workspace APIs
# Default: http://localhost:3001
VITE_API_URL=http://localhost:3001

# Pydantic Backend (Python) - AI Agent Service
# Used for: Agent execution, Tool discovery, Deployment management
# Default: http://localhost:8001
VITE_BACKEND_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Chrome Extension Build Configuration (Optional)
# -----------------------------------------------------------------------------
# These are typically set via CLI during build/dev commands
# You don't need to manually set these unless you have specific requirements

# CEB_EXAMPLE=example_env
# CEB_DEV_LOCALE=
# CEB_CI=

# -----------------------------------------------------------------------------
# Production Example
# -----------------------------------------------------------------------------
# For production deployments, update the URLs to your actual service endpoints:
#
# VITE_API_URL=https://runtime.yourdomain.com
# VITE_BACKEND_URL=https://pydantic.yourdomain.com
#
# Note: Ensure CORS is properly configured on your backend services to allow
# requests from your Chrome extension origin.
# -----------------------------------------------------------------------------
